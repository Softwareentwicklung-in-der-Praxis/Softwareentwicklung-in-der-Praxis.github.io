---
const { title, emoji } = Astro.props;
---

<li>
    <div class="p-6 bg-slate-50 rounded-xl shadow text-center mx-6 my-4">
        <div class="grid grid-cols-[200px_1fr] gap-4 items-center">            
            <h3 class="text-2xl text-nowrap">
                <span aria-hidden="true">{emoji}</span> {title}
            </h3>
            <p class="text-lg text-left"><slot /></p>
        </div>
    </div>
</li>

